generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["silos"]
}

model Empresa {
  id              Int       @id @default(autoincrement())
  razao_social    String    @db.VarChar(200)
  nome_fantasia   String?   @db.VarChar(200)
  cnpj            String    @unique @db.VarChar(18)
  logradouro      String?   @db.VarChar(300)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.Char(2)
  cep             String?   @db.VarChar(10)
  telefone        String?   @db.VarChar(20)
  email           String?   @db.VarChar(200)
  status          String    @default("ativa") @db.VarChar(10)
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()

  usuarios        Usuario[]
  silos           Silo[]

  @@map("empresas")
  @@schema("silos")
}

model Usuario {
  id              Int       @id @default(autoincrement())
  nome_completo   String    @db.VarChar(200)
  email           String    @unique @db.VarChar(200)
  senha_hash      String    @db.VarChar(255)
  perfil          String    @db.VarChar(30)
  empresa_id      Int?
  status          String    @default("ativo") @db.VarChar(10)
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()

  empresa         Empresa?  @relation(fields: [empresa_id], references: [id])
  eventos         Evento[]

  @@map("usuarios")
  @@schema("silos")
}

model Silo {
  id              Int       @id @default(autoincrement())
  empresa_id      Int
  nome            String    @db.VarChar(200)
  logradouro      String?   @db.VarChar(300)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.Char(2)
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  descricao       String?   @db.Text
  status          String    @default("ativo") @db.VarChar(10)
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()
  id_labrador     Int?

  empresa         Empresa              @relation(fields: [empresa_id], references: [id])
  barras          Barra[]
  alertas         Alerta[]
  esquematico_overlays EsquematicoOverlay[]
  carregamentos   Carregamento[]
  eventos         Evento[]

  @@map("silos")
  @@schema("silos")
}

model Carregamento {
  id              Int      @id @default(autoincrement())
  silo_id         Int
  hora_referencia DateTime @db.Timestamptz()
  nivel_m         Decimal  @db.Decimal(6, 2)
  volume_sacos    Decimal  @db.Decimal(12, 2)
  criado_em       DateTime @default(now()) @db.Timestamptz()
  atualizado_em   DateTime @default(now()) @updatedAt @db.Timestamptz()

  silo            Silo     @relation(fields: [silo_id], references: [id])

  @@index([silo_id, hora_referencia(sort: Desc)])
  @@map("carregamento")
  @@schema("silos")
}

model Evento {
  id                 Int      @id @default(autoincrement())
  silo_id            Int
  hora_referencia    DateTime @db.Timestamptz()
  usuario_id         Int
  descricao_resumida String   @db.VarChar(200)
  descricao_completa String?  @db.Text
  criado_em          DateTime @default(now()) @db.Timestamptz()
  atualizado_em      DateTime @default(now()) @updatedAt @db.Timestamptz()

  silo               Silo     @relation(fields: [silo_id], references: [id])
  usuario            Usuario  @relation(fields: [usuario_id], references: [id])

  @@index([silo_id, hora_referencia(sort: Desc)])
  @@map("eventos")
  @@schema("silos")
}

model EsquematicoOverlay {
  id          Int    @id @default(autoincrement())
  silo_id     Int
  vista       String @db.VarChar(30)
  entity_type String @db.VarChar(10)
  entity_id   Int
  x1          Float
  y1          Float
  x2          Float
  y2          Float

  silo        Silo   @relation(fields: [silo_id], references: [id], onDelete: Cascade)

  @@unique([silo_id, vista, entity_type, entity_id])
  @@map("esquematico_overlays")
  @@schema("silos")
}

model Barra {
  id              Int       @id @default(autoincrement())
  silo_id         Int
  identificacao   String    @db.VarChar(100)
  local           String    @default("interno ao silo") @db.VarChar(30)
  status          String    @default("ativa") @db.VarChar(10)
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()
  id_labrador     Int?
  dxf_handle      String?   @db.VarChar(20)

  silo            Silo                @relation(fields: [silo_id], references: [id])
  sensores        Sensor[]
  comunicacoes    ComunicacaoStatus[]

  @@map("barras")
  @@schema("silos")
}

model Sensor {
  id                Int              @id @default(autoincrement())
  barra_id          Int
  identificacao     String           @db.VarChar(100)
  altura_solo_m     Decimal          @db.Decimal(6, 2)
  tipo_grandeza     String           @db.VarChar(20)
  unidade_medida    String           @db.VarChar(10)
  status            String           @default("ativo") @db.VarChar(10)
  criado_em         DateTime         @default(now()) @db.Timestamptz()
  atualizado_em     DateTime         @default(now()) @updatedAt @db.Timestamptz()
  id_labrador       Int?
  dxf_handle        String?          @db.VarChar(20)

  barra             Barra            @relation(fields: [barra_id], references: [id])
  leituras_internas LeituraInterna[]
  leituras_externas LeituraExterna[]

  @@map("sensores")
  @@schema("silos")
}

model LeituraInterna {
  id              BigInt    @id @default(autoincrement())
  sensor_id       Int
  timestamp       DateTime  @db.Timestamptz()
  valor_avg       Decimal   @db.Decimal(10, 4)
  valor_max       Decimal   @db.Decimal(10, 4)
  valor_min       Decimal   @db.Decimal(10, 4)
  num_amostras    Int
  desvio_padrao   Decimal?  @db.Decimal(10, 4)
  sum             BigInt?
  sum2            BigInt?
  status_analise  String?

  sensor          Sensor    @relation(fields: [sensor_id], references: [id])

  @@unique([sensor_id, timestamp], name: "leitura_interna_sensor_timestamp_uq")
  @@index([sensor_id, timestamp(sort: Desc)], name: "leitura_interna_sensor_ts_desc_idx")
  @@map("leitura_interna")
  @@schema("silos")
}

model LeituraExterna {
  id              BigInt    @id @default(autoincrement())
  sensor_id       Int
  timestamp       DateTime  @db.Timestamptz()
  temp_avg        Float?
  umid_avg        Float?
  n_amostras      Int
  rele            Boolean?
  sht_online      Boolean?
  fw              String    @db.VarChar(20)

  sensor          Sensor    @relation(fields: [sensor_id], references: [id])

  @@unique([sensor_id, timestamp], name: "leitura_externa_sensor_timestamp_uq")
  @@map("leitura_externa")
  @@schema("silos")
}

model ComunicacaoStatus {
  id              BigInt    @id @default(autoincrement())
  barra_id        Int
  timestamp       DateTime  @db.Timestamptz()
  uptime_esp32_s   Int?
  rssi_dbm        Int?
  snr_db          Float?

  barra           Barra     @relation(fields: [barra_id], references: [id])

  @@map("comunicacao_status")
  @@schema("silos")
}

model Alerta {
  id              Int       @id @default(autoincrement())
  silo_id         Int
  descricao       String    @db.Text
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()

  silo            Silo      @relation(fields: [silo_id], references: [id])

  @@map("alertas")
  @@schema("silos")
}

model Faq {
  id              Int       @id @default(autoincrement())
  pergunta_pt     String    @db.Text
  pergunta_en     String    @db.Text
  pergunta_es     String    @db.Text
  resposta_pt     String    @db.Text
  resposta_en     String    @db.Text
  resposta_es     String    @db.Text
  ordem           Int       @default(0)
  status          String    @default("rascunho") @db.VarChar(15)
  criado_em       DateTime  @default(now()) @db.Timestamptz()
  atualizado_em   DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@map("faq")
  @@schema("silos")
}

model SolicitacaoContato {
  id                    Int       @id @default(autoincrement())
  nome                  String    @db.VarChar(200)
  empresa               String?   @db.VarChar(200)
  email                 String    @db.VarChar(200)
  telefone              String?   @db.VarChar(20)
  mensagem              String    @db.Text
  data_hora             DateTime  @default(now()) @db.Timestamptz()
  status                String    @default("novo") @db.VarChar(20)
  observacoes_internas  String?   @db.Text

  @@map("solicitacoes_contato")
  @@schema("silos")
}
